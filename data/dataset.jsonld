{
 "@context": "https://schema.org",
 "@type": "Dataset",
 "@id": "https://bigbirdreturns.github.io/undercast/#dataset",
 "identifier": "undercast",
 "name": "UNDERCAST",
 "description": "A provenance-first field index of performers who vanish under prosthetics, masks, creature suits, performance capture, or an unseen voice.",
 "url": "https://bigbirdreturns.github.io/undercast/",
 "version": "1",
 "creator": {
  "@type": "Organization",
  "name": "UNDERCAST contributors"
 },
 "isAccessibleForFree": true,
 "keywords": [
  "performers",
  "prosthetics",
  "creature suits",
  "masks",
  "performance capture",
  "voice performance",
  "evidence graph"
 ],
 "distribution": [
  {
   "@type": "DataDownload",
   "name": "Canonical specimen catalog",
   "encodingFormat": "application/json",
   "contentUrl": "https://bigbirdreturns.github.io/undercast/data/specimens.json"
  },
  {
   "@type": "DataDownload",
   "name": "Canonical constellation evidence graph",
   "encodingFormat": "application/json",
   "contentUrl": "https://bigbirdreturns.github.io/undercast/data/constellations.json"
  },
  {
   "@type": "DataDownload",
   "name": "Archive contract",
   "encodingFormat": "application/json",
   "contentUrl": "https://bigbirdreturns.github.io/undercast/data/archive.json"
  },
  {
   "@type": "DataDownload",
   "name": "Derived entity index",
   "encodingFormat": "application/json",
   "contentUrl": "https://bigbirdreturns.github.io/undercast/data/entities.json"
  },
  {
   "@type": "DataDownload",
   "name": "Franchise census coverage",
   "encodingFormat": "application/json",
   "contentUrl": "https://bigbirdreturns.github.io/undercast/data/CENSUS-COVERAGE.json"
  }
 ]
}
