{
  "version": 1,
  "schema": "schema/corpus-operations.schema.json",
  "mode": "collection-only",
  "effective_from": "2026-07-24",
  "semantics": "UNDERCAST v1 is in collection operations. The default work is to discover, preserve, verify, add, correct, and improve corpus records; product expansion requires an explicit exception or owner decision.",
  "product_freeze": {
    "status": "active",
    "allowed_change_classes": [
      "corpus-addition",
      "source-refresh",
      "evidence-improvement",
      "media-search",
      "media-correction",
      "correction",
      "rights",
      "preservation",
      "adapter-build",
      "adapter-certification",
      "operations",
      "security",
      "accessibility",
      "performance"
    ],
    "owner_decision_required": [
      "new-reader-surface",
      "new-primary-navigation",
      "new-character-performer-reveal",
      "new-runtime-service",
      "new-canonical-entity-type",
      "new-account-or-contributor-system",
      "new-public-write-interface"
    ]
  },
  "loops": [
    {
      "id": "incident-and-correction",
      "priority": 1000,
      "authority": "operator",
      "cadence": "continuous",
      "terminal_condition": "No open high or critical incident and no known public correctness or rights defect."
    },
    {
      "id": "source-refresh",
      "priority": 900,
      "authority": "operator",
      "cadence": "per-certified-scope",
      "terminal_condition": "Every active scope is within its declared refresh cadence and its certification/source snapshot remains current."
    },
    {
      "id": "bounded-growth",
      "priority": 800,
      "authority": "luna-with-reviewed-receipt",
      "cadence": "one-waterline-cycle",
      "terminal_condition": "The lease is terminal, all resulting media debt is closed, and a reviewed cycle receipt exists."
    },
    {
      "id": "media-improvement",
      "priority": 700,
      "authority": "reviewer",
      "cadence": "rolling",
      "terminal_condition": "Each attempted facet is either promoted through hash-bound review, honestly unchanged, or receives a dated no-result receipt."
    },
    {
      "id": "lead-harvest",
      "priority": 600,
      "authority": "machine",
      "cadence": "daily",
      "terminal_condition": "New leads are queued with provenance; no lead becomes canonical without the bounded growth path."
    },
    {
      "id": "estate-induction",
      "priority": 500,
      "authority": "second-desk-and-owner",
      "cadence": "dependency-gated",
      "terminal_condition": "One estate advances exactly one reviewed stage without activating an uncertified producer."
    }
  ],
  "quality_policy": {
    "max_growth_lease": 8,
    "media_absence_retry_days": 90,
    "blocked_task_retry_days": 30,
    "never_overwrite_verified_media_automatically": true,
    "candidate_media_is_noncanonical": true,
    "media_promotion_requires_hash_bound_review": true,
    "unknown_is_null_not_zero": true,
    "source_failure_may_not_publish_zero": true
  },
  "estate_pipeline": {
    "stages": [
      "discovered",
      "inventory",
      "adapter-build",
      "adapter-review",
      "certified-paused",
      "active",
      "retired"
    ],
    "activation_requirements": [
      "source-model-documented",
      "adapter-specific-fixtures-pass",
      "exact-source-revisions-preserved",
      "regenerated-corpus-semantically-reviewed",
      "producer-certification-current",
      "baseline-media-policy-defined",
      "scope-explicitly-activated"
    ],
    "parallel_active_estates": 1,
    "next_estate_requires_completed_milestones": [
      "star-trek-gold-shard",
      "operational-reliability"
    ]
  }
}
