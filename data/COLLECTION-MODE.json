{
  "version": 1,
  "schema": "schema/collection-mode.schema.json",
  "mode": "collection-only",
  "activated_at": "2026-07-24T00:00:00.000Z",
  "authority": "owner",
  "product_contract": "frozen-v1",
  "semantics": "The default operating state extends, verifies, preserves and corrects the existing archive. New product surfaces, reveal mechanics, schema concepts or services require an explicit owner decision; ordinary operation adds corpus records, improves evidence and media, refreshes certified sources, and inducts new IP estates through reviewed adapters.",
  "default_mutations": [
    "corpus-addition",
    "evidence-improvement",
    "media-candidate",
    "media-remediation",
    "source-refresh",
    "adapter-certification",
    "estate-inventory",
    "correction",
    "rights-response",
    "preservation",
    "security",
    "accessibility",
    "performance",
    "operations"
  ],
  "protected_paths": [
    "index.html",
    "recognition.html",
    "coverage.html",
    "constellation.html",
    "404.html",
    "assets/site-tokens.css",
    "assets/site-shell.css",
    "assets/record-page.css",
    "assets/coverage.css",
    "assets/constellation.css",
    "scripts/build-record-pages.mjs",
    "schema/specimen.schema.json",
    "schema/archive.schema.json",
    "docs/PRODUCT-CONSTITUTION.md",
    "docs/DESIGN-SYSTEM.md"
  ],
  "override_labels": {
    "owner_product_change": "owner-approved-product-change",
    "narrow_hotfixes": [
      "correctness-hotfix",
      "security-hotfix",
      "rights-hotfix",
      "accessibility-hotfix",
      "performance-hotfix"
    ]
  },
  "growth": {
    "one_cycle_at_a_time": true,
    "default_batch_limit": 1,
    "maximum_batch_limit": 8,
    "require_active_certified_scope": true,
    "require_zero_media_debt_before_next_cycle": true,
    "require_reviewed_cycle_receipt": true
  },
  "rolling_media_search": {
    "canonical_write": false,
    "batch_limit": 40,
    "missing_retry_days": 30,
    "attention_retry_days": 7,
    "nonfree_portrait_retry_days": 180,
    "verified_portrait_retry_days": 365,
    "verified_still_retry_days": 730,
    "artifact_retention_days": 90
  },
  "estate_policy": {
    "activation": "One newly certified estate at a time until the Star Trek gold reference and operational-reliability milestones carry reviewed completion receipts.",
    "selection": "Use evidence quality, source durability and reviewer capacity; never infer priority from popularity alone.",
    "required_sequence": [
      "inventory",
      "source-model-review",
      "adapter-build",
      "adapter-review",
      "certified-paused",
      "active-corpus",
      "gold-reference"
    ]
  }
}
