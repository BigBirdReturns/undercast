{
  "version": 1,
  "semantics": "Each scope maps a reviewed census producer into the generic Luna queue. Declared active is not enough: the producer contract must also have a current AUTOPILOT-CERTIFICATIONS receipt and the current census snapshot must retain its required source receipts.",
  "default_worker": "luna",
  "scopes": [
    {
      "id": "star-trek",
      "label": "Star Trek",
      "status": "active",
      "priority": 1000,
      "coverage_match": {
        "franchise": "Star Trek"
      },
      "refresh": {
        "cadence_days": 7,
        "steps": [
          {
            "label": "rediscover full-canon Star Trek scope",
            "executable": "node",
            "args": [
              "scripts/census-scope.mjs"
            ]
          },
          {
            "label": "refresh Star Trek performer-role census",
            "executable": "node",
            "args": [
              "scripts/census.mjs",
              "star-trek"
            ]
          }
        ]
      },
      "certification": {
        "producer_files": [
          "scripts/census-fixtures.mjs",
          "scripts/census-key.mjs",
          "scripts/census-scope.mjs",
          "scripts/census.mjs",
          "scripts/lib/census-core.mjs"
        ],
        "checks": [
          {
            "label": "census producer regression fixtures",
            "executable": "node",
            "args": [
              "scripts/census-fixtures.mjs"
            ]
          }
        ],
        "require_manifest_receipts": true,
        "require_source_snapshot": true
      },
      "note": "First certified full-corpus rollout. New Luna leases require a published exact-revision source snapshot for the current census."
    },
