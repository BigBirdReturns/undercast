{
  "version": 1,
  "semantics": "Each scope maps a trustworthy census producer into the generic Luna queue. Adding a show is data configuration once its adapter emits exact performer-role coverage and pinned source receipts; the worker state machine does not change.",
  "default_worker": "luna",
  "scopes": [
    {
      "id": "star-trek",
      "label": "Star Trek",
      "status": "active",
      "priority": 1000,
      "coverage_match": { "franchise": "Star Trek" },
      "refresh": { "executable": "node", "args": ["scripts/census.mjs", "star-trek"], "cadence_days": 7 },
      "note": "First full-corpus rollout. The full-canon census can feed this contract without worker changes."
    },
    {
      "id": "doctor-who",
