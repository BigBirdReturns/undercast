@@ -54,7 +54,7 @@
             --lock "$work/AUTOPILOT.lock" \
             --json > "$work/status.json"
           node scripts/autopilot.mjs validate --state "$work/AUTOPILOT.json"
-          node -e 'const fs=require("fs"); const s=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); const trek=s.scopes?.["star-trek"]; if (!trek?.total) throw new Error("actual census produced no Star Trek tasks"); console.log(`actual census queue: Star Trek ${trek.total}; claimable ${trek.statuses?.queued||0}; attention ${trek.statuses?.attention||0}; resolved ${trek.statuses?.resolved||0}`);' "$work/status.json"
+          node -e 'const fs=require("fs"); const s=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); const trek=s.scopes?.["star-trek"]; const ready=(s.readiness||[]).find(r=>r.scope_id==="star-trek"); if (!trek?.total) throw new Error("actual census produced no Star Trek tasks"); const queued=trek.statuses?.queued||0; if (ready?.effective_status!=="active" && queued) throw new Error(`uncertified Star Trek scope produced ${queued} claimable tasks`); console.log(`actual census queue: Star Trek ${trek.total}; effective ${ready?.effective_status}; claimable ${queued}; attention ${trek.statuses?.attention||0}; resolved ${trek.statuses?.resolved||0}`);' "$work/status.json"
       - name: Validate semantic corpus invariants
         run: npm run audit:corpus
       - name: Validate public site seams
