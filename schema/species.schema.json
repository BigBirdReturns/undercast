{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/species.schema.json",
  "title": "UNDERCAST sourced species navigation projection",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "generated_from", "semantics", "taxa"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "schema": { "const": "schema/species.schema.json" },
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage", "unresolved", "vocabulary", "specimens"],
      "properties": {
        "coverage": { "$ref": "#/$defs/input" },
        "unresolved": { "$ref": "#/$defs/input" },
        "vocabulary": { "$ref": "#/$defs/input" },
        "specimens": { "$ref": "#/$defs/input" }
      }
    },
    "semantics": { "type": "string", "minLength": 20 },
    "taxa": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/taxon" }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 4 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["named_credits", "distinct_performers", "physical_credits", "voice_credits", "unresolved_mode_credits", "unresolved_characters", "filed_role_credits", "filed_records", "unfiled_named_credits"],
      "properties": {
        "named_credits": { "type": "integer", "minimum": 0 },
        "distinct_performers": { "type": "integer", "minimum": 0 },
        "physical_credits": { "type": "integer", "minimum": 0 },
        "voice_credits": { "type": "integer", "minimum": 0 },
        "unresolved_mode_credits": { "type": "integer", "minimum": 0 },
        "unresolved_characters": { "type": "integer", "minimum": 0 },
        "filed_role_credits": { "type": "integer", "minimum": 0 },
        "filed_records": { "type": "integer", "minimum": 0 },
        "unfiled_named_credits": { "type": "integer", "minimum": 0 }
      }
    },
    "credit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["character", "performer", "performance_mode", "source"],
      "properties": {
        "character": { "type": "string", "minLength": 1 },
        "performer": { "type": "string", "minLength": 2 },
        "performance_mode": { "enum": ["physical-prosthetic", "physical-and-voice", "voice-animation", "unresolved"] },
        "source": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "credits"],
      "properties": {
        "id": { "type": "string", "pattern": "^UC-G?\\d+$" },
        "credits": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/credit" } }
      }
    },
    "unknown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["character", "performance_mode", "source", "reason"],
      "properties": {
        "character": { "type": "string", "minLength": 1 },
        "performance_mode": { "enum": ["physical-prosthetic", "physical-and-voice", "voice-animation", "unresolved"] },
        "source": { "type": "string", "format": "uri", "pattern": "^https://" },
        "reason": { "type": "string", "minLength": 10 }
      }
    },
    "taxon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "franchise", "source_category", "source_url", "wall_route", "coverage_route", "counts", "records", "unresolved_characters"],
      "properties": {
        "key": { "type": "string", "pattern": "^species:[a-z0-9-]+:[a-z0-9-]+$" },
        "label": { "type": "string", "minLength": 2 },
        "franchise": { "type": "string", "minLength": 2 },
        "source_category": { "type": "string", "minLength": 2 },
        "source_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "wall_route": { "type": "string", "pattern": "^index\\.html\\?species=" },
        "coverage_route": { "type": "string", "pattern": "^coverage\\.html\\?" },
        "counts": { "$ref": "#/$defs/counts" },
        "records": { "type": "array", "items": { "$ref": "#/$defs/record" } },
        "unresolved_characters": { "type": "array", "items": { "$ref": "#/$defs/unknown" } }
      }
    }
  }
}
