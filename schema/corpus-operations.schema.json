{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/corpus-operations.schema.json",
  "title": "UNDERCAST corpus operations contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "mode", "effective_from", "semantics", "product_freeze", "loops", "quality_policy", "estate_pipeline"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "schema": { "const": "schema/corpus-operations.schema.json" },
    "mode": { "const": "collection-only" },
    "effective_from": { "type": "string", "format": "date" },
    "semantics": { "type": "string", "minLength": 40 },
    "product_freeze": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "allowed_change_classes", "owner_decision_required"],
      "properties": {
        "status": { "const": "active" },
        "allowed_change_classes": { "type": "array", "minItems": 8, "uniqueItems": true, "items": { "type": "string", "minLength": 3 } },
        "owner_decision_required": { "type": "array", "minItems": 4, "uniqueItems": true, "items": { "type": "string", "minLength": 3 } }
      }
    },
    "loops": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "priority", "authority", "cadence", "terminal_condition"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "priority": { "type": "integer", "minimum": 1 },
          "authority": { "type": "string", "minLength": 3 },
          "cadence": { "type": "string", "minLength": 3 },
          "terminal_condition": { "type": "string", "minLength": 20 }
        }
      }
    },
    "quality_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_growth_lease", "media_absence_retry_days", "blocked_task_retry_days", "never_overwrite_verified_media_automatically", "candidate_media_is_noncanonical", "media_promotion_requires_hash_bound_review", "unknown_is_null_not_zero", "source_failure_may_not_publish_zero"],
      "properties": {
        "max_growth_lease": { "type": "integer", "minimum": 1, "maximum": 8 },
        "media_absence_retry_days": { "type": "integer", "minimum": 1 },
        "blocked_task_retry_days": { "type": "integer", "minimum": 1 },
        "never_overwrite_verified_media_automatically": { "const": true },
        "candidate_media_is_noncanonical": { "const": true },
        "media_promotion_requires_hash_bound_review": { "const": true },
        "unknown_is_null_not_zero": { "const": true },
        "source_failure_may_not_publish_zero": { "const": true }
      }
    },
    "estate_pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages", "activation_requirements", "parallel_active_estates", "next_estate_requires_completed_milestones"],
      "properties": {
        "stages": { "type": "array", "minItems": 7, "uniqueItems": true, "items": { "type": "string", "minLength": 3 } },
        "activation_requirements": { "type": "array", "minItems": 6, "uniqueItems": true, "items": { "type": "string", "minLength": 3 } },
        "parallel_active_estates": { "type": "integer", "minimum": 1 },
        "next_estate_requires_completed_milestones": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 3 } }
      }
    }
  }
}
