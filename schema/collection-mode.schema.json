{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/collection-mode.schema.json",
  "title": "UNDERCAST collection-only operating contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "mode", "activated_at", "authority", "product_contract", "semantics", "default_mutations", "protected_paths", "override_labels", "growth", "rolling_media_search", "estate_policy"],
  "properties": {
    "version": {"const": 1},
    "schema": {"const": "schema/collection-mode.schema.json"},
    "mode": {"const": "collection-only"},
    "activated_at": {"type": "string", "format": "date-time"},
    "authority": {"const": "owner"},
    "product_contract": {"const": "frozen-v1"},
    "semantics": {"type": "string", "minLength": 80},
    "default_mutations": {"type": "array", "minItems": 8, "uniqueItems": true, "items": {"type": "string"}},
    "protected_paths": {"type": "array", "minItems": 8, "uniqueItems": true, "items": {"type": "string"}},
    "override_labels": {"type": "object"},
    "growth": {"type": "object"},
    "rolling_media_search": {"type": "object"},
    "estate_policy": {"type": "object"}
  }
}
