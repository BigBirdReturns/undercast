{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/tombstones.schema.json",
  "title": "UNDERCAST retired identifier ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "records"],
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "records": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/merged" },
          { "$ref": "#/$defs/removed" }
        ]
      }
    }
  },
  "$defs": {
    "merged": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "successor", "reason"],
      "properties": {
        "id": { "type": "string", "pattern": "^UC-G?\\d+$" },
        "status": { "type": "string", "enum": ["merged"] },
        "successor": { "type": "string", "pattern": "^UC-G?\\d+$" },
        "reason": { "type": "string", "minLength": 12 }
      }
    },
    "removed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "actor", "character", "reason", "source"],
      "properties": {
        "id": { "type": "string", "pattern": "^UC-G?\\d+$" },
        "status": { "type": "string", "enum": ["removed"] },
        "actor": { "type": "string", "minLength": 1 },
        "character": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 12 },
        "source": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    }
  }
}
