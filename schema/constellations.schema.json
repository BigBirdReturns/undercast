{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/constellations.schema.json",
  "title": "UNDERCAST constellation evidence graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "semantics", "nodes", "edges", "constellations"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "schema": { "type": "string", "pattern": "^schema/constellations\\.schema\\.json$" },
    "semantics": { "type": "string", "minLength": 1 },
    "nodes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/edge" } },
    "constellations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/constellation" } }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "description", "source"],
      "properties": {
        "id": { "type": "string", "pattern": "^(person|character|episode|production|franchise):[a-z0-9-]+$" },
        "kind": { "type": "string", "enum": ["person", "character", "episode", "production", "franchise"] },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "format": "uri", "pattern": "^https://" },
        "record_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^UC-G?\\d+$" } }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "source", "publisher"],
      "properties": {
        "label": { "type": "string", "minLength": 4 },
        "source": { "type": "string", "format": "uri", "pattern": "^https://" },
        "publisher": { "type": "string", "minLength": 2 }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "predicate", "scope", "note", "evidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^edge:[a-z0-9-]+$" },
        "from": { "type": "string", "minLength": 3 },
        "to": { "type": "string", "minLength": 3 },
        "predicate": { "type": "string", "enum": ["performed", "appears_in", "installment_of", "belongs_to"] },
        "scope": { "type": "string", "enum": ["specimen", "context", "structure"] },
        "note": { "type": "string", "minLength": 1 },
        "record_id": { "type": "string", "pattern": "^UC-G?\\d+$" },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } }
      }
    },
    "constellation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "kicker", "summary", "node_ids", "edge_ids"],
      "properties": {
        "id": { "type": "string", "pattern": "^constellation:[a-z0-9-]+$" },
        "title": { "type": "string", "minLength": 1 },
        "kicker": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "node_ids": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 3 } },
        "edge_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^edge:[a-z0-9-]+$" } }
      }
    }
  }
}
