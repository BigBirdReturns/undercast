{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/estate-registry.schema.json",
  "title": "UNDERCAST IP-estate operating registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "semantics", "state_order", "estates"],
  "properties": {
    "version": {"const": 1},
    "schema": {"const": "schema/estate-registry.schema.json"},
    "semantics": {"type": "string", "minLength": 60},
    "state_order": {"type": "array", "minItems": 8, "uniqueItems": true, "items": {"type": "string"}},
    "estates": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "label", "priority", "state", "autopilot_scope", "wall_shelf", "source_hosts", "next_gate"]}}
  }
}
