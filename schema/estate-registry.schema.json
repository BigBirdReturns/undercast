{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/estate-registry.schema.json",
  "title": "UNDERCAST estate induction registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "semantics", "discovery", "estates"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "semantics": { "type": "string", "minLength": 40 },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_source", "inventory_unit", "automatic_classification", "unmapped_productions_remain_visible"],
      "properties": {
        "canonical_source": { "const": "data/specimens.json" },
        "inventory_unit": { "type": "string", "minLength": 10 },
        "automatic_classification": { "const": false },
        "unmapped_productions_remain_visible": { "const": true }
      }
    },
    "estates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "priority", "stage", "scope_id", "source_model", "sources", "next_gate"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 2 },
          "priority": { "type": "integer", "minimum": 1 },
          "stage": { "enum": ["discovered", "inventory", "adapter-build", "adapter-review", "certified-paused", "active", "retired"] },
          "scope_id": { "type": ["string", "null"] },
          "source_model": { "type": "string", "minLength": 12 },
          "sources": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
          "next_gate": { "type": "string", "minLength": 20 }
        }
      }
    }
  }
}
