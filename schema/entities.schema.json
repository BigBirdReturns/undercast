{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/entities.schema.json",
  "title": "UNDERCAST derived entity projection",
  "type": "object",
  "required": ["version", "schema", "generated_from", "semantics", "performers", "productions", "makers"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "schema": { "type": "string", "pattern": "^schema/entities\\.schema\\.json$" },
    "generated_from": { "type": "object", "required": ["path", "content_sha256"] },
    "semantics": { "type": "string", "minLength": 1 },
    "performers": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "productions": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "makers": { "type": "array", "items": { "$ref": "#/$defs/entity" } }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "record_ids"],
      "properties": {
        "key": { "type": "string", "minLength": 8 },
        "label": { "type": "string", "minLength": 1 },
        "record_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^UC-G?\\d+$" } }
      }
    }
  }
}
