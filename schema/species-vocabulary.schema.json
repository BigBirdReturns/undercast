{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/species-vocabulary.schema.json",
  "title": "UNDERCAST maintained species vocabulary",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "schema", "semantics", "taxa"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "schema": { "const": "schema/species-vocabulary.schema.json" },
    "semantics": { "type": "string", "minLength": 20 },
    "taxa": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "franchise", "source_category", "source_url"],
        "properties": {
          "key": { "type": "string", "pattern": "^species:[a-z0-9-]+:[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 2 },
          "franchise": { "type": "string", "minLength": 2 },
          "source_category": { "type": "string", "minLength": 2 },
          "source_url": { "type": "string", "format": "uri", "pattern": "^https://" }
        }
      }
    }
  }
}
