{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://bigbirdreturns.github.io/undercast/schema/census-test.schema.json",
 "title": "UNDERCAST source-scoped census benchmark report",
 "type": "object",
 "required": ["version", "test", "scope", "status", "accounting_status", "pass_definition", "input_sha256", "constellation_id", "wall_coverage_complete", "physical_blockers", "source_rows", "counts", "errors", "dispositions"],
 "properties": {
  "version": { "type": "integer", "minimum": 1 },
  "test": { "type": "string", "enum": ["ferengi-source-scoped-discoverability"] },
  "scope": { "type": "object", "required": ["franchise", "category"] },
  "status": { "type": "string", "enum": ["PASS", "FAIL"] },
  "accounting_status": { "type": "string", "enum": ["PASS", "FAIL"] },
  "pass_definition": { "type": "string", "minLength": 1 },
  "input_sha256": { "type": "object" },
  "constellation_id": { "type": ["string", "null"] },
  "wall_coverage_complete": { "type": "boolean" },
  "physical_blockers": { "type": "integer", "minimum": 0 },
  "source_rows": { "type": "integer", "minimum": 1 },
  "raw_performer_role_rows": { "type": "integer", "minimum": 1 },
  "performer_role_credits": { "type": "integer", "minimum": 1 },
  "normalized_source_aliases": { "type": "array" },
  "unresolved_characters": { "type": "integer", "minimum": 0 },
  "counts": { "type": "object", "required": ["covered", "excluded-with-reason", "unresolved-with-evidence"] },
  "errors": { "type": "array", "items": { "type": "string" } },
  "dispositions": {
   "type": "array",
   "minItems": 1,
   "items": {
    "type": "object",
    "required": ["key", "disposition", "franchise", "category", "character", "performer", "source"],
    "properties": {
     "key": { "type": "string", "minLength": 1 },
     "disposition": { "type": "string", "enum": ["covered", "excluded-with-reason", "unresolved-with-evidence"] },
     "franchise": { "type": "string", "minLength": 1 },
     "category": { "type": "string", "minLength": 1 },
     "character": { "type": "string", "minLength": 1 },
     "performer": { "type": ["string", "null"] },
     "reason": { "type": "string", "minLength": 1 },
     "source": { "type": "string", "format": "uri" },
     "performance_mode": { "type": "string" },
     "edge_id": { "type": "string" },
     "wall_ids": { "type": "array", "items": { "type": "string" } }
    }
   }
  }
 }
}
