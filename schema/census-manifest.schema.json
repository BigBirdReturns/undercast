{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://bigbirdreturns.github.io/undercast/schema/census-manifest.schema.json",
 "title": "UNDERCAST census source-observation manifest",
 "type": "object",
 "additionalProperties": false,
 "required": ["version", "schema", "captured_at", "generator", "scope", "observations", "snapshots"],
 "properties": {
  "version": { "type": "integer", "minimum": 1 },
  "schema": { "type": "string", "pattern": "^schema/census-manifest\\.schema\\.json$" },
  "captured_at": { "type": ["string", "null"] },
  "generator": { "type": "string", "minLength": 1 },
  "scope": {
   "type": "object",
   "additionalProperties": false,
   "required": ["franchises", "category"],
   "properties": {
    "franchises": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "category": { "type": ["string", "null"] }
   }
  },
  "observations": {
   "type": "array",
   "items": { "$ref": "#/$defs/observation" }
  },
  "snapshots": {
   "type": "object",
   "additionalProperties": false,
   "required": ["census", "unresolved"],
   "properties": {
    "census": { "$ref": "#/$defs/snapshot" },
    "unresolved": { "$ref": "#/$defs/snapshot" }
   }
  }
 },
 "$defs": {
  "snapshot": {
   "type": "object",
   "additionalProperties": false,
   "required": ["path", "sha256", "rows"],
   "properties": {
    "path": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "rows": { "type": "integer", "minimum": 0 }
   }
  },
  "observation": {
   "type": "object",
   "additionalProperties": false,
   "required": ["franchise", "category", "title", "source", "observed_at", "pageid", "revision", "timestamp", "content_sha256", "disposition"],
   "properties": {
    "franchise": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "format": "uri", "pattern": "^https://" },
    "observed_at": { "type": "string", "minLength": 1 },
    "pageid": { "type": "integer", "minimum": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "disposition": { "type": "string", "enum": ["credited", "unresolved", "out-of-scope", "category-member"] }
   }
  }
 }
}
