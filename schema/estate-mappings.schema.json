{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/estate-mappings.schema.json",
  "title": "UNDERCAST exact estate mappings",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "semantics", "mappings"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "semantics": { "type": "string", "minLength": 40 },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "value", "estate_id"],
        "properties": {
          "field": { "enum": ["universe", "production"] },
          "value": { "type": "string", "minLength": 1 },
          "estate_id": { "type": "string", "pattern": "^[a-z0-9-]+$" }
        }
      }
    }
  }
}
