{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbirdreturns.github.io/undercast/schema/archive.schema.json",
  "title": "UNDERCAST archive contract",
  "type": "object",
  "required": ["version", "catalog_id", "canonical_url", "identifiers", "canonical", "schemas", "path_bases", "projections", "routes", "discovery", "policies", "web_assets"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "catalog_id": { "type": "string", "pattern": "^undercast$" },
    "schema": { "type": "string", "pattern": "^schema/archive\\.schema\\.json$" },
    "title": { "type": "string", "minLength": 1 },
    "canonical_url": { "type": "string", "pattern": "^https://" },
    "description": { "type": "string", "minLength": 1 },
    "identifiers": { "type": "object", "required": ["record_pattern", "record_key", "never_reuse_ids"] },
    "canonical": { "type": "object", "required": ["records", "sources", "constellations", "tombstones"] },
    "schemas": { "type": "object", "required": ["archive", "specimen", "source", "entities", "constellations"] },
    "path_bases": { "type": "object", "required": ["contract_paths", "shard_manifest_children"] },
    "projections": { "type": "object", "required": ["lean_index", "shard_manifest", "entities", "search", "media_live", "quality", "census"] },
    "vocabularies": { "type": "object", "required": ["conditions"] },
    "routes": { "type": "object", "required": ["record", "interactive_record", "wall_record", "filtered_wall", "constellation"] },
    "discovery": { "type": "object", "required": ["robots", "sitemap", "dataset", "crawler_guide"] },
    "policies": { "type": "object", "required": ["truth", "evidence", "cache", "privacy"] },
    "web_assets": { "type": "array", "minItems": 1 }
  }
}
