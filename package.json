    "serve": "python3 -m http.server 8000",
    "curate": "node scripts/curate.mjs",
    "test:census": "node scripts/census-fixtures.mjs",
    "roadmap": "node scripts/roadmap.mjs",
    "roadmap:fixtures": "node scripts/roadmap-fixtures.mjs",
    "preserve:sources": "node scripts/preserve-sources.mjs",
    "preserve:originals": "node scripts/preserve-bag.mjs",
    "preserve:verify": "node scripts/preserve-verify.mjs",
    "preserve:status": "node scripts/preserve-status.mjs",
    "preserve:receipt": "node scripts/preserve-receipt.mjs",
    "preserve:fixtures": "node scripts/preservation-fixtures.mjs",
