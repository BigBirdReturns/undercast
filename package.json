    "ds9:summary": "node scripts/ds9-census.mjs --project-only",
    "ds9:graph": "node scripts/ds9-graph.mjs",
    "ds9:graph:project": "node scripts/ds9-graph.mjs --project-only",
    "ds9:fixtures": "node scripts/ds9-fixtures.mjs",
    "ds9:eligibility:adjudicate": "node scripts/ds9-eligibility-adjudicate.mjs",
