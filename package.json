{
  "name": "undercast",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A field index of performers who vanish under a designed face.",
  "scripts": {
    "ingest": "node scripts/ingest.mjs",
    "retrieve": "node scripts/retrieve.mjs",
    "needs": "node scripts/needs.mjs",
    "adopt": "node scripts/adopt.mjs",
    "pin": "node scripts/pin.mjs",
    "credits": "node scripts/credits.mjs",
    "build": "node scripts/retrieve.mjs && node scripts/credits.mjs",
    "build:contract": "node scripts/build-contract.mjs",
    "build:site": "node scripts/build-contract.mjs && node scripts/build-record-pages.mjs",
    "validate": "node scripts/validate.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:focus": "node scripts/focus-audit.mjs",
    "audit:corpus": "node scripts/corpus-audit.mjs",
    "sync:sources": "node scripts/sync-sources.mjs",
    "census:ferengi": "node scripts/census.mjs star-trek --category Ferengi",
    "census:klingons": "node scripts/census.mjs star-trek --category Klingons",
    "ds9:census": "node scripts/ds9-census.mjs",
    "ds9:summary": "node scripts/ds9-census.mjs --project-only",
    "ds9:graph": "node scripts/ds9-graph.mjs",
    "ds9:graph:project": "node scripts/ds9-graph.mjs --project-only",
    "ds9:fixtures": "node scripts/ds9-fixtures.mjs",
    "ds9:eligibility:adjudicate": "node scripts/ds9-eligibility-adjudicate.mjs",
    "ds9:eligibility:queue": "node scripts/ds9-eligibility-queue.mjs",
    "ds9:eligibility:fixtures": "node scripts/ds9-eligibility-fixtures.mjs",
    "build:species": "node scripts/build-species.mjs",
    "build:ferengi": "node scripts/build-ferengi-constellation.mjs",
    "build:changelings": "node scripts/build-ds9-changeling-constellation.mjs",
    "test:ferengi": "node scripts/census-gate.mjs --write",
    "test:site-seams": "node scripts/site-seams.mjs",
    "test:rendered": "playwright test",
    "grow": "node scripts/grow.mjs",
    "serve": "python3 -m http.server 8000",
    "curate": "node scripts/curate.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
