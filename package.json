    "ds9:decide": "node scripts/ds9-decide.mjs",
    "ds9:decide:fixtures": "node scripts/ds9-decide-fixtures.mjs",
    "ds9:maker:adjudicate": "node scripts/ds9-maker-adjudicate.mjs",
